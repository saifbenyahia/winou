PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=hive_tn

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

KONNECT_API_KEY=your_konnect_api_key
KONNECT_BASE_URL=https://api.sandbox.konnect.network/api/v2
KONNECT_RECEIVER_WALLET_ID=your_receiver_wallet_id
KONNECT_WEBHOOK_URL=http://localhost:5000/api/payments/konnect/webhook
KONNECT_SUCCESS_URL=http://localhost:5173/payment/success
KONNECT_FAIL_URL=http://localhost:5173/payment/fail

# Optional Konnect tuning
KONNECT_TIMEOUT_MS=15000
KONNECT_PAYMENT_LIFESPAN_MINUTES=30
KONNECT_CHECKOUT_FORM=true
KONNECT_ADD_PAYMENT_FEES_TO_AMOUNT=false
KONNECT_ACCEPTED_PAYMENT_METHODS=wallet,bank_card,e-DINAR
KONNECT_THEME=light
